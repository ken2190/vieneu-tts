# Docker image name and tag (used by docker-compose.prod.yml)
IMAGE_NAME=vieneu-tts
IMAGE_TAG=latest

# Host port mapping
PORT=7860

# Host directory for HuggingFace model cache (mounted into container at /root/.cache/huggingface)
MODELS_DIR=./models

# HuggingFace token (for gated models)
# HF_TOKEN=hf_...

# Set to 1 to generate a public Gradio share link
GRADIO_SHARE=0

# LMDeploy serve config
SERVE_PORT=23333
SERVE_MODEL=pnnbao-ump/VieNeu-TTS
